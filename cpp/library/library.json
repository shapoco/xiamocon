{
    "name": "xmc_library",
    "version": "0.0.2",
    "build": {
        "includeDir": "include",
        "srcDir": "src",
        "srcFilter": [
            "+<*>",
            "+<audio/*>",
            "+<geo/*>",
            "+<gfx/*>",
            "+<../ext/fatfs/*>",
            "+<../ext/tjpgd/*>"
        ],
        "unflags": [
            "-Os",
            "-fno-jump-tables",
            "-fno-tree-switch-conversion"
        ],
        "flags": [
            "-std=gnu++17",
            "-O2",
            "-fjump-tables",
            "-ftree-switch-conversion",
            "-Iinclude",
            "-Iext/fatfs",
            "-Iext/tjpgd",
            "-Iext/gfxfont"
        ]
    },
    "export": {
        "include": [
            "include",
            "ext/fatfs",
            "ext/tjpgd",
            "ext/gfxfont"
        ]
    },
    "platforms": "*",
    "dependencies": [
        "xmc_platform"
    ]
}